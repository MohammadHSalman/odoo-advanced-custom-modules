<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- إدراج الحقل في بطاقة المنتج (نموذج القالب فقط) بعد سعر البيع مباشرة -->
    <record id="view_product_template_form_consumer_price" model="ir.ui.view">
        <field name="name">product.template.form.consumer.price</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <!-- بعد list_price -->
            <xpath expr="//div[@name='list_price_uom']" position="after">
                <field name="consumer_price" optional="show"/>
                <field name="msl_flag" optional="show"/>
                <field name="sales_channel_ids" widget="many2many_tags"/>
            </xpath>
        </field>
    </record>

    <!-- (اختياري) إظهاره أيضًا في نموذج المنتج العام لو احتجت -->
    <record id="view_product_form_consumer_price" model="ir.ui.view">
        <field name="name">product.product.form.consumer.price</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='list_price_uom']" position="after">
                <field name="consumer_price" optional="show"/>
                <field name="msl_flag" optional="show"/>
                <field name="sales_channel_ids" widget="many2many_tags"/>
            </xpath>
        </field>
    </record>

    <record id="view_product_form_category" model="ir.ui.view">
        <field name="name">product.category.form.consumer.price</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parent_id']" position="after">
                <field name="msl_flag" optional="show"/>
            </xpath>
        </field>
    </record>


</odoo>
