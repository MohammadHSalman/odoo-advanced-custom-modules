<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Main Tracking Menu -->
    <menuitem id="menu_tracking_root"
              name="Tracking"
              sequence="50"
              parent="menu_route_root"
              groups="sales_rep_manager.sales_rep_manager"/>

    <!-- Map Action -->
    <record id="action_location_map" model="ir.actions.client">
        <field name="name">Sales Representative Route Map</field>
        <field name="tag">sales_rep_location_map</field>
    </record>

    <menuitem id="menu_location_map"
              name="Sales Representatives Map"
              parent="menu_tracking_root"
              action="action_location_map"
              sequence="2"
              groups="sales_rep_manager.sales_rep_manager"/>

    <!-- List View for Location Records -->
    <record id="view_sales_rep_location_list" model="ir.ui.view">
        <field name="name">sales.rep.location.list</field>
        <field name="model">sales.rep.location</field>
        <field name="arch" type="xml">
            <list string="Location Records" default_order="location_time desc" create="false">
                <field name="sales_rep_id"/>
                <field name="latitude"/>
                <field name="longitude"/>
                <field name="location_time"/>
            </list>
        </field>
    </record>

    <record id="action_sales_rep_location_list" model="ir.actions.act_window">
        <field name="name">Location Records</field>
        <field name="res_model">sales.rep.location</field>
        <field name="view_mode">list</field>
        <field name="context">{"search_default_today": 1}</field>
    </record>

    <menuitem id="menu_sales_rep_location_list"
              name="Location Records"
              parent="menu_tracking_root"
              action="action_sales_rep_location_list"
              sequence="1"
              groups="sales_rep_manager.sales_rep_manager"/>

</odoo>