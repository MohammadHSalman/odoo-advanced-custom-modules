<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Tree / List View -->
    <record id="view_cashvan_invoice_log_tree" model="ir.ui.view">
        <field name="name">cashvan.invoice.log.tree</field>
        <field name="model">cashvan.invoice.log</field>
        <field name="arch" type="xml">
            <list string="CashVan Invoice Logs">
                <field name="create_date"/>
                <field name="user_id"/>
                <field name="partner_id"/>
                <field name="mobile_invoice_number"/>
                <field name="error_stage"/>
                <field name="error_message"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_cashvan_invoice_log_form" model="ir.ui.view">
        <field name="name">cashvan.invoice.log.form</field>
        <field name="model">cashvan.invoice.log</field>
        <field name="arch" type="xml">
            <form string="CashVan Invoice Log">
                <sheet>
                    <group>
                        <field name="create_date"/>
                        <field name="user_id"/>
                        <field name="partner_id"/>
                        <field name="mobile_invoice_number"/>
                        <field name="error_stage"/>
                        <field name="error_message"/>
                        <field name="payload"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Menu Item -->

    <!-- Action -->
    <record id="action_cashvan_invoice_log" model="ir.actions.act_window">
        <field name="name">CashVan Invoice Logs</field>
        <field name="res_model">cashvan.invoice.log</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                This is where failed CashVan invoices are logged automatically.
            </p>
        </field>
    </record>

    <menuitem id="menu_cashvan_invoice_log" name="Invoice Logs" sequence="1000"
              parent="menu_route_root" action="action_cashvan_invoice_log"/>

</odoo>