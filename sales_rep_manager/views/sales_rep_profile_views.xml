<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_sales_rep_profile_form" model="ir.ui.view">
        <field name="name">sales.rep.profile.form</field>
        <field name="model">sales.rep.profile</field>
        <field name="arch" type="xml">
            <form string="Sales Representative Profile">
                <sheet>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="name" readonly="1"/>
                            <field name="company_id"/>
                            <field name="attachment_mandatory"/>
                            <field name="allow_usd_payment"/>
                            <field name="allow_manual_offer"/>
                            <field name="allowed_distance_m"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="location_id"/>
                            <field name="sales_team_type"/>
                            <field name="route_id"/>
                            <field name="is_trackable"/>

                            <field name="location_time" required="is_trackable" invisible="not is_trackable"/>
                            <field name="operation_type_id"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Stock Settings">
                            <group>
                                <group>
                                    <field name="picking_type_id"
                                           options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"/>
                                    <field name="user_name" invisible="1"/>

                                    <field name="filtered_location_id"
                                           domain="[('company_id', '=', company_id), ('name', '!=', user_name)]"
                                           options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"/>
                                </group>
                                <group>
                                    <field name="category_ids" widget="many2many_tags"
                                           options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"/>
                                </group>
                            </group>
                        </page>

                        <page string="Cash Journals">
                            <group>
                                <field name="journal_tag_ids"
                                       widget="many2many_tags"
                                       context="{'show_currency_in_name': True}"
                                       domain="[('id','in', available_cash_journal_ids)]"
                                       options="{'no_create_edit': True}"/>

                                <field name="journal_map_ids"
                                       invisible="1"
                                       context="{'default_profile_id': id}"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sales_rep_profile_list" model="ir.ui.view">
        <field name="name">sales.rep.profile.list</field>
        <field name="model">sales.rep.profile</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="location_id"/>
                <field name="sales_team_type"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="action_sales_rep_profile" model="ir.actions.act_window">
        <field name="name">Sales Rep Profiles</field>
        <field name="res_model">sales.rep.profile</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
    </record>

    <menuitem id="menu_sales_rep_profile" name="Profiles" parent="menu_route_root"
              action="action_sales_rep_profile" sequence="0"/>

</odoo>
