<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_picking_inherit_remove_barcode"
              inherit_id="stock.report_picking">

        <xpath expr="//th[@name='th_barcode']" position="replace">
        </xpath>

        <xpath expr="//td[hasclass('text-center')][last()]" position="replace">
        </xpath>

        <xpath expr="//t[@t-set='has_barcode']" position="replace">
        </xpath>
        <xpath expr="//p[@t-field='o.note']" position="before">

            <hr/>

            <div class="row mt-4">
                <div class="col-6"/>

                <div class="col-6">
                    <table class="table table-sm">
                        <tbody>
                            <tr>
                                <td>
                                    <strong>مجمل الكميات:</strong>
                                </td>
                                <td class="text-right">
                                    <t t-esc="sum(o.move_line_ids.mapped('quantity'))"/>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <strong>عدد الأقلام:</strong>
                                </td>
                                <td class="text-right">
                                    <t t-esc="len(o.move_line_ids.mapped('product_id'))"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="oe_structure mb-4"/>

        </xpath>
    </template>
</odoo>