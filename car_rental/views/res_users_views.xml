<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    xml to add new fields to the hr.employee-->
    <record id="view_user_form" model="ir.ui.view">
        <field name="name">hr.user.view.form.inherit</field>
        <field name="model">res.users</field>
        <field name="type">form</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='access_rights']" position="after">
                <page string="Admin Access Right" name="access_right" >
                    <group>
                        <group>
                            <field name="is_super_admin"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
