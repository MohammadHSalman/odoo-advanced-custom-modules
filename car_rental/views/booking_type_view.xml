<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="booking_type_view_form_MHAZAS" model="ir.ui.view">
        <field name="name">booking type view form</field>
        <field name="model">booking.type</field>
        <field name="arch" type="xml">
            <form string="Allowed KM">
                <sheet>
                    <group>
                        <group>
                            <field name="booking_type"/>
                            <field name="days_no"/>
<!--                            <field name="allowed_fuel"/>-->
                        </group>
                        <group>
                            <field name="allowed_km"/>
                            <field name="daily_allowed_km"/>
<!--                            <field name="daily_allowed_fuel"/>-->
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="booking_type_view_tree_MHAZAS" model="ir.ui.view">
        <field name="name">booking type view tree</field>
        <field name="model">booking.type</field>
        <field name="arch" type="xml">
            <tree string="Allowed KM">
                <field name="booking_type"/>
                <field name="days_no"/>
                <field name="allowed_km"/>
                <field name="daily_allowed_km"/>
            </tree>
        </field>
    </record>

    <record model="ir.actions.act_window" id="booking_type_action_window_MHAZAS">
        <field name="name">Allowed KM</field>
        <field name="res_model">booking.type</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record model="ir.actions.server" id="booking_type_action_server_MHAZAS">
        <field name="name">Allowed KM</field>
        <field name="model_id" ref="model_booking_type"/>
        <field name="state">code</field>
        <field name="code">
            action = {
            "type": "ir.actions.act_window",
            "view_mode": "tree,form",
            "res_model": model._name,
            }
        </field>
    </record>

<!--    <menuitem id="menu_configration_MHAZAS" name="Configration"-->
<!--              parent="vehicle_rental.main_menu_vehicle_rental" sequence="5"/>-->

    <menuitem id="menu_booking_type_MHAZAS"
              name="Allowed KM"
              parent="vehicle_rental.menu_configuration"
              action="booking_type_action_window_MHAZAS"
              sequence="1"/>
</odoo>