<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    xml to add new fields to the hr.employee-->
    <record id="view_user_form" model="ir.ui.view">
        <field name="name">hr.user.view.form.inherit.pos.access.right.hr</field>
        <field name="model">res.users</field>
        <field name="type">form</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='access_right']//group" position="inside">
                <field name="disable_cancellation"/>
            </xpath>
        </field>
    </record>
</odoo>
