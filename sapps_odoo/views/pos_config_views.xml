<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Inherit the form view of pos.config to add a new field -->
        <record id="view_pos_config_form_inherit" model="ir.ui.view">
            <field name="name">pos.config.form.inherit</field>
            <field name="model">pos.config</field>
            <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
            <field name="arch" type="xml">
                <!-- Insert the new field "pos_num" after the "other_devices" setting -->
                <xpath expr="//field[@name='name']" position="after">
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_right_pane">
                            <div>
                                <!-- Label for the new field -->
                                <label for="pos_num" string="POS Number"/>
                            </div>
                            <div>
                                <!-- Field for entering the POS number -->
                                <field name="pos_num"/>
                                <div class="text-muted mb16">
                                    <!-- Optional helper text can be added here -->
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
