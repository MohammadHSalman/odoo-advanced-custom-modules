<?xml version='1.0' encoding='UTF-8'?>
<odoo>
  <record id="view_pos_order_audit_log_tree" model="ir.ui.view">
    <field name="name">pos.order.audit.log.tree</field>
    <field name="model">pos.order.audit.log</field>
    <field name="arch" type="xml">
      <list string="POS Order Audit Logs">
        <field name="action"/>
        <field name="user_id"/>
        <field name="pos_order_id"/>
        <!--                <field name="create_time"/>-->
        <field name="receipt_num"/>
        <field name="product_id"/>
        <field name="quantity"/>
        <field name="price_unit"/>
        <field name="timestamp"/>
      </list>
    </field>
  </record>
  <record id="action_pos_order_audit_log" model="ir.actions.act_window">
    <field name="name">POS Order Audit Logs</field>
    <field name="res_model">pos.order.audit.log</field>
    <field name="view_mode">list</field>
  </record>
  <menuitem id="menu_pos_order_audit" name="POS Order Audit" parent="point_of_sale.menu_point_of_sale" action="action_pos_order_audit_log"/>
</odoo>
