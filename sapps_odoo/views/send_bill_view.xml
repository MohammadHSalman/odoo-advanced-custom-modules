<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model="ir.ui.menu" id="account.menu_action_tax_form">
            <field name="groups_id" eval="[Command.set([ref('base.group_no_one')])]"/>
        </record>
        <!-- Inherit Form View to Modify it -->
        <record id="view_out_invoice_tree_inherit" model="ir.ui.view">
            <field name="name">view out invoice tree inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_out_invoice_tree"/>
            <field name="arch" type="xml">
                <field name="status_in_payment" position="before">
                    <field name="financial_status"/>
                </field>

            </field>
        </record>

        <!-- Inherit Form View to Modify it -->
        <record id="product_template_only_form_view_inherit" model="ir.ui.view">
            <field name="name">product template only form view inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='taxes_id']" position="attributes">
                    <attribute name="groups">base.group_no_one</attribute>
                </xpath>
            </field>
        </record>
        <record id="view_bill_success_wizard_form" model="ir.ui.view">
            <field name="name">bill.success.wizard.form</field>
            <field name="model">bill.success.wizard</field>
            <field name="arch" type="xml">
                <form string="????? ???????">
                    <sheet>
                        <div style="text-align: center; padding: 20px; font-size: 18px; color: #2e7d32;">
                            <field name="message" nolabel="1" widget="text"/>
                        </div>
                    </sheet>
                    <footer>
                        <!-- ??? ???? ?????? ???? ??????? -->
                        <button name="action_confirm_and_reload"
                                string="Confirm"
                                type="object"
                                class="btn-primary"/>
                    </footer>
                </form>
            </field>
        </record>

        <!--  action button for send invoice      -->
        <record id="action_add_bill" model="ir.actions.server">
            <field name="name">Send to Finance</field>
            <field name="type">ir.actions.server</field>
            <field name="model_id" ref="model_account_move"/>
            <field name="binding_model_id" ref="model_account_move"/>
            <field name="binding_view_types">list</field>
            <field name="groups_id" eval="[(4, ref('sapps_odoo.group_send_finance_bill'))]"/>
            <field name="state">code</field>
            <field name="code">
                action = records.send_multi_bill()
            </field>
        </record>


        <!-- Inherit Form View to Modify it -->
        <record id="view_move_form_inherit" model="ir.ui.view">
            <field name="name">view move form inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_date']" position="attributes">
                    <attribute name="widget">date</attribute>
                </xpath>
                <xpath expr="//field[@name='name']" position="after">
<!--                    <field name="custom_invoice_number"/>-->
                    <field name="printed" invisible="1"/>
                </xpath>
                <xpath expr="//button[@name='button_draft']" position='attributes'>
                    <attribute name="invisible">is_posted == True</attribute>
                </xpath>

                <xpath expr="//field[@name='payment_reference']" position='after'>
                    <field name="date_bill" readonly="1" invisible="1"/>
                </xpath>
<!--                <xpath expr="//page/group/group/field[@name = 'to_check']" position="after">-->
<!--                    <field name="qr_code" widget='image' class="qr_code_sapps"-->
<!--                           style="height: 130px;width: 130px;margin-left: -4%;"/>-->
<!--                </xpath>-->

                <xpath expr="//button[@name='action_post']" position="after">
                    <button name="send_bill" string="Send to Finance" type="object"
                            groups="sapps_odoo.group_send_finance_bill"
                            style="background: #d14545;color: white;"
                            invisible="state == 'draft' or financial_status == 'Posted to Finance' or move_type not in ['out_invoice']"></button>

                </xpath>

                <xpath expr="//page[@id='other_tab']" position="after">
                    <page id="Info_financial" string="Financial Info" invisible="move_type != 'out_invoice'">
                        <group id="financial_info">
                            <group name="Financial Information">
                                <field name="is_posted" invisible="1"/>
                                <field name="financial_status" readonly="1"/>
                                <field name="code" readonly="1"/>
                                <field name="bill_date" readonly="1"/>
                                <field name="random_number" readonly="1"/>
                                <field name="qr_code" widget='image' class="qr_code_sapps"
                                       style="height: 130px;width: 130px;margin-left: -4%;"/>
                                <field name="sent_payload"/>

                                <!--                                                                <field name="code_uuid" readonly="1"/>-->
                            </group>
                            
                        </group>
                    </page>
                </xpath>
                <xpath expr="//group[@class='oe_subtotal_footer']/field[@name='tax_totals']" position="after">
                    
                        <field name="total_before_discount" string="Total Before Discount" readonly="1"/>
                        <field name="discount_value" string="Discount Value" readonly="1"/>
                
                </xpath>
            </field>
        </record>

        <record id="view_account_invoice_filter_inherit" model="ir.ui.view">
            <field name="name">view account invoice filter inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_account_invoice_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='cancel']" position="after">
                    <separator/>
                    <filter string="Posted to Finance" name="posted_to_finance"
                            domain="[('financial_status','=','Posted to Finance')]"/>
                    <filter string="Not Posted to Finance" name="not_posted_to_finance"
                            domain="[('financial_status','!=','Posted to Finance')]"/>
                    <separator/>
                </xpath>

            </field>
        </record>
    </data>
</odoo>