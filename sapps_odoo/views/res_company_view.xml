<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Inherit the company form view to add new financial fields -->
        <record id="view_res_company_form_inherit_financial" model="ir.ui.view">
            <field name="name">res.company.form.inherit.financial</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <!-- Add classification field after currency_id -->
                <xpath expr="//field[@name='currency_id']" position="after">
                    <field name="pos_num_acc"/>
                    <field name="classification"/>
                </xpath>
                <!-- Add financial approval fields after classification -->
                <xpath expr="//field[@name='classification']" position="after">
                    <field name="financial_approval_number"/>
                    <field name="financial_approval_date"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
