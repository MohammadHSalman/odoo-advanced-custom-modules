<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inherit the account.tax form view to add the rounding field -->
        <record id="view_tax_form_inherit" model="ir.ui.view">
            <field name="name">account.tax.form.rounding.inherit</field>
            <field name="model">account.tax</field>
            <field name="inherit_id" ref="account.view_tax_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='tax_scope']" position="after">
                    <field name="rounding"/>
                    <field name="unique_tax_num" invisible="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
