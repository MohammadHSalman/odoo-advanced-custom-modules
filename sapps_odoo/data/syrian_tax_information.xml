<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Update Configuration Settings -->
<!--        <record id="update_config_settings" model="res.config.settings">-->
<!--            <field name="account_fiscal_country_id" ref="base.sy"/>-->
<!--            <field name="currency_id" ref="base.SYP"/>-->
<!--        </record>-->

<!--         Delete All Existing Taxes-->
<!--        <delete model="account.tax" />-->

        <!-- Define New Tax Group -->
        <record id="tax_group_syrian_tax_authority" model="account.tax.group">
            <field name="name">هيئة الضرائب والرسوم السورية</field>
            <field name="sequence">11</field>
            <field name="country_id" ref="base.sy"/>
        </record>

        <!-- Define Consumer Spending Tax -->
        <record id="tax_consumer_spending_5" model="account.tax">
            <field name="name">إنفاق استهلاكي (5%)</field>
            <field name="type_tax_use">sale</field>
            <field name="tax_group_id" ref="tax_group_syrian_tax_authority"/>
            <field name="amount_type">percent</field>
            <field name="amount">5</field>
            <field name="unique_tax_num">0.05</field>
            <field name="country_id" ref="base.sy"/>
            <field name="description">إنفاق استهلاكي (5%)</field>
            <field name="rounding">100</field>
            <field name="invoice_label">إنفاق استهلاكي (5%)</field>
        </record>

        <!-- Define Local Administration Tax -->
        <record id="tax_local_administration_5_percent" model="account.tax">
            <field name="name">إدارة محلية (5% من الضريبة)</field>
            <field name="type_tax_use">sale</field>
            <field name="tax_group_id" ref="tax_group_syrian_tax_authority"/>
            <field name="amount_type">percent</field>
            <field name="amount">0.25</field>
            <field name="unique_tax_num">0.25</field>
            <field name="country_id" ref="base.sy"/>
            <field name="rounding">100</field>
            <field name="description">إدارة محلية (5% من الضريبة)</field>
            <field name="invoice_label">إدارة محلية (5% من الضريبة)</field>
        </record>

        <!-- Define Reconstruction Tax -->
        <record id="tax_reconstruction_10_percent" model="account.tax">
            <field name="name">إعادة إعمار (10% من الضريبة)</field>
            <field name="type_tax_use">sale</field>
            <field name="tax_group_id" ref="tax_group_syrian_tax_authority"/>
            <field name="amount_type">percent</field>
            <field name="amount">0.5</field>
            <field name="unique_tax_num">0.5</field>
            <field name="country_id" ref="base.sy"/>
            <field name="rounding">100</field>
            <field name="description">إعادة إعمار (10% من الضريبة)</field>
            <field name="invoice_label">إعادة إعمار (10% من الضريبة)</field>
        </record>

        <!-- Optional Cron Job for Posting to Finance -->
        <record id="cron_send_invoice_to_finance" model="ir.cron">
            <field name="name">Invoice Post to Finance</field>
            <field name="priority">2</field>
<!--            <field name="doall">False</field>-->
            <field name="active">False</field>
<!--            <field name="numbercall">-1</field>-->
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="model_id" ref="model_account_move"/>
            <field name="state">code</field>
            <field name="code">model.run_send_invoice_to_finance()</field>
        </record>
        <record id="cron_send_order_to_finance" model="ir.cron">
            <field name="name">Order Post to Finance</field>
            <field name="priority">2</field>
<!--            <field name="doall">False</field>-->
            <field name="active">False</field>
<!--            <field name="numbercall">-1</field>-->
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="model_id" ref="model_pos_order"/>
            <field name="state">code</field>
            <field name="code">model.run_send_order_to_finance()</field>
        </record>
    </data>
</odoo>
